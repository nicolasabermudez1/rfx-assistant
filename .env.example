# === REQUIRED ===
GEMINI_API_KEY=AIza...
# === OPTIONAL ===
GEMINI_MODEL_PRIMARY=gemini-2.0-flash
GEMINI_MODEL_FAST=gemini-2.0-flash-lite
# === DEMO CONFIG ===
DEMO_PORT_STREAMLIT=8501
DEMO_LOG_LEVEL=INFO
DEMO_TRACE_DIR=data/runs
# Set to 1 to force pre-computed responses (no live API calls). The demo runs perfectly either way.
DEMO_OFFLINE_MODE=1
